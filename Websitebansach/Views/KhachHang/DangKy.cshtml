@model Websitebansach.Models.KhachHang
@{
    ViewBag.Title = "Đăng Ký";
    Layout = "~/Views/Layout/NguoidungLayout.cshtml";
}

<h2>Đăng Ký</h2>

@using (Html.BeginForm("DangKy", "KhachHang", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div class="form-horizontal">
        <h4>Thông Tin Khách Hàng</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.Label("Họ tên", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.HoTen, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.HoTen, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Tài khoản", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.TaiKhoan, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.TaiKhoan, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Mật khẩu", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.PasswordFor(m => m.MatKhau, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label for="XacNhanMatKhau" class="control-label col-md-2">Xác nhận mật khẩu</label>
            <div class="col-md-10">
                <input type="password" name="XacNhanMatKhau" class="form-control" />
                @Html.ValidationMessage("XacNhanMatKhau", "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Địa chỉ", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.DiaChi, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.DiaChi, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Điện thoại", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(m => m.DienThoai, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(m => m.DienThoai, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Giới tính", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(m => m.GioiTinh, new SelectList(new[]
                {
                    new { Value = "Nam", Text = "Nam" },
                    new { Value = "Nữ", Text = "Nữ" },
                    new { Value = "Khác", Text = "Khác" }
                }, "Value", "Text"), "Chọn giới tính", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.GioiTinh, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Ngày sinh", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <input type="date" id="NgaySinh" name="NgaySinh" class="form-control" />
                @Html.ValidationMessageFor(m => m.NgaySinh, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Đăng Ký" class="btn btn-primary" />
            </div>
        </div>
    </div>
}
